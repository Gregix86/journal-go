# Copie ce fichier en ".env" (sans .example) et remplis les vraies valeurs.
# Ne commit JAMAIS le fichier ".env" reel dans Git (voir .gitignore).

# Cle secrete pour signer les cookies de session admin - genere une longue chaine aleatoire
SECRET_KEY=remplace-moi-par-une-longue-chaine-aleatoire

SITE_NAME=Mon Carnet

# Compte admin n°1 (toi)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-moi

# Compte admin n°2 (ta copine) - laisse vide pour ne pas le creer
ADMIN2_USERNAME=
ADMIN2_PASSWORD=
